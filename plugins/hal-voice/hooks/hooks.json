{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$d = [Console]::In.ReadToEnd(); $d | python \"${CLAUDE_PLUGIN_ROOT}/scripts/pre_tool_status.py\"",
            "timeout": 20
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$d = [Console]::In.ReadToEnd(); $d | python \"${CLAUDE_PLUGIN_ROOT}/scripts/track_action.py\"",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Start-Process -FilePath python -ArgumentList '\"${CLAUDE_PLUGIN_ROOT}/scripts/hal_announce.py\"' -WindowStyle Hidden",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
