{
  "_comment": "Merge this 'hooks' block into your %USERPROFILE%\\.claude\\settings.json. Adjust the hardcoded python.exe path to match your machine (or use 'python' if it's on PATH).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "async": true,
            "command": "$d = [Console]::In.ReadToEnd(); $d | C:\\Users\\braxt\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"$env:USERPROFILE\\.claude\\scripts\\pre_tool_status.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "async": true,
            "command": "$d = [Console]::In.ReadToEnd(); $d | C:\\Users\\braxt\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"$env:USERPROFILE\\.claude\\scripts\\track_action.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "async": true,
            "command": "C:\\Users\\braxt\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"$env:USERPROFILE\\.claude\\scripts\\ut2003_announce.py\""
          }
        ]
      }
    ]
  }
}
